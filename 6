const SIGNATURE_IDS = [2, 4, 26, 33, 46, 50]; // 精選招牌料理（未勾選時顯示）

let selectedIngredients = new Set();
let currentTab = "minimalist";
let filteredRecipes = [];

const ingredientGroupsEl = document.getElementById("ingredientGroups");
const recipeGridEl = document.getElementById("recipeGrid");
const recipeSectionTitleEl = document.getElementById("recipeSectionTitle");
const tabBarEl = document.getElementById("tabBar");
const tabMinimalistEl = document.getElementById("tabMinimalist");
const tabPremiumEl = document.getElementById("tabPremium");
const emptyStateEl = document.getElementById("emptyState");
const magicBtn = document.getElementById("magicBtn");
const slotOverlay = document.getElementById("slotOverlay");
const selectedCountEl = document.getElementById("selectedCount");
const clearBtn = document.getElementById("clearBtn");

/* ===================== 渲染食材勾選區 ===================== */
function renderIngredientGroups(){
  ingredientGroupsEl.innerHTML = ingredientGroupsData.map((group, gIdx) => `
    <div>
      <h3 class="font-display font-bold text-base sm:text-lg mb-3 category-pill inline-block pb-1" style="color:var(--food-yellow); border-color: var(--food-yellow);">
        ${group.title}
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
        ${group.items.map((item, iIdx) => `
          <label class="relative cursor-pointer block">
            <input type="checkbox" class="hidden ingredient-checkbox" data-name="${item}" id="ing-${gIdx}-${iIdx}" />
            <div class="ingredient-card rounded-2xl bg-gray-50 border-2 border-gray-100 p-3 flex flex-col items-center gap-1 text-center">
              <span class="ing-emoji text-2xl">${group.emojiMap[item] || "🍴"}</span>
              <span class="font-bold text-sm">${item}</span>
            </div>
          </label>
        `).join("")}
      </div>
    </div>
  `).join("");

  document.querySelectorAll(".ingredient-checkbox").forEach(cb => {
    cb.addEventListener("change", (e) => {
      const name = e.target.dataset.name;
      if (e.target.checked) selectedIngredients.add(name);
      else selectedIngredients.delete(name);
      selectedCountEl.textContent = `目前選了 ${selectedIngredients.size} 種食材`;
    });
  });
}

clearBtn.addEventListener("click", () => {
  selectedIngredients.clear();
  document.querySelectorAll(".ingredient-checkbox").forEach(cb => cb.checked = false);
  selectedCountEl.textContent = `目前選了 0 種食材`;
});

/* ===================== 食譜卡片渲染 ===================== */
function recipeCardHTML(r, idx){
  const styleBadge = r.style === "minimalist"
    ? `<span class="text-xs font-bold px-2 py-1 rounded-full bg-gray-900 text-white">地獄極簡風 ⚡️</span>`
    : `<span class="text-xs font-bold px-2 py-1 rounded-full" style="background: var(--food-yellow); color:#3b2a06;">偽高級餐廳風 👑</span>`;

  // 「食材全滿 / 缺料」標籤 —— 只有篩選結果（有 missingIngredients 屬性）才會顯示
  let statusBadge = "";
  if (r.missingIngredients !== undefined){
    statusBadge = r.isPerfect
      ? `<span class="text-xs font-bold px-2 py-1 rounded-full bg-green-500 text-white">🎯 食材全滿</span>`
      : `<span class="text-xs font-bold px-2 py-1 rounded-full bg-gray-100 text-gray-600">缺：${r.missingIngredients.join("、")}</span>`;
  }

  return `
    <div class="recipe-card bg-white rounded-2xl shadow-md p-5 border border-gray-100 cursor-pointer" style="animation-delay:${idx * 0.05}s" onclick="openRecipeModal(${r.id})">
      <div class="flex items-start justify-between gap-2 mb-2 flex-wrap">
        <h3 class="font-display font-bold text-lg leading-snug" style="color:var(--magic-purple-dark);">${r.name}</h3>
        <div class="flex flex-wrap gap-1 justify-end">
          ${styleBadge}
          ${statusBadge}
        </div>
      </div>
      <p class="text-sm text-gray-600 mb-3">${r.desc}</p>
      <div class="flex items-center justify-between text-xs text-gray-400 font-semibold">
        <span>⏱ ${r.time}</span>
        <span class="truncate max-w-[60%] text-right">${r.ingredients.join(" · ")}</span>
      </div>
      <div class="mt-3 pt-3 border-t border-gray-100 text-xs font-bold text-right" style="color:var(--magic-purple);">點擊看魔法步驟 ➔</div>
    </div>
  `;
}

function renderSignatureRecipes(){
  recipeSectionTitleEl.textContent = "✨ 主廚精選招牌料理";
  tabBarEl.classList.add("hidden");
  emptyStateEl.classList.add("hidden");
  const sigRecipes = SIGNATURE_IDS.map(id => recipes.find(r => r.id === id));
  recipeGridEl.innerHTML = sigRecipes.map((r, i) => recipeCardHTML(r, i)).join("");
}

/* 核心篩選邏輯：OR 比對（命中至少 1 樣食材即列入）＋ 命中數排序 ＋ 缺料標示 */
function renderFilteredRecipes(){
  recipeSectionTitleEl.textContent = "🎉 符合條件的食譜";
  tabBarEl.classList.remove("hidden");
  updateTabUI();

  const have = selectedIngredients; // Set，目前勾選的食材

  let matched = recipes.map(recipe => {
    const hasIngredients = recipe.ingredients.filter(ing => have.has(ing));
    const missingIngredients = recipe.ingredients.filter(ing => !have.has(ing));
    return {
      ...recipe,
      matchCount: hasIngredients.length,
      missingIngredients,
      isPerfect: missingIngredients.length === 0,
    };
  });

  // 只要命中 1 個以上食材就留下（OR 邏輯，取代原本要求全中的 AND 邏輯）
  matched = matched.filter(r => r.matchCount > 0);

  // 完美匹配排最前，其餘依命中數量多寡排序
  matched.sort((a, b) => {
    if (a.isPerfect && !b.isPerfect) return -1;
    if (!a.isPerfect && b.isPerfect) return 1;
    return b.matchCount - a.matchCount;
  });

  filteredRecipes = matched;
  renderRecipesForTab();
}

function renderRecipesForTab(){
  const list = filteredRecipes.filter(r => r.style === currentTab);
  if (list.length === 0){
    recipeGridEl.innerHTML = "";
    emptyStateEl.classList.remove("hidden");
  } else {
    emptyStateEl.classList.add("hidden");
    recipeGridEl.innerHTML = list.map((r, i) => recipeCardHTML(r, i)).join("");
  }
}

function updateTabUI(){
  tabMinimalistEl.classList.remove("active-minimalist");
  tabPremiumEl.classList.remove("active-premium");
  if (currentTab === "minimalist") tabMinimalistEl.classList.add("active-minimalist");
  else tabPremiumEl.classList.add("active-premium");
}

tabMinimalistEl.addEventListener("click", () => { currentTab = "minimalist"; updateTabUI(); renderRecipesForTab(); });
tabPremiumEl.addEventListener("click", () => { currentTab = "premium"; updateTabUI(); renderRecipesForTab(); });

/* ===================== 施展魔法按鈕 ===================== */
function spawnSparkles(){
  const rect = magicBtn.getBoundingClientRect();
  const emojis = ["✨","🌟","⭐","💫"];
  for (let i = 0; i < 8; i++){
    const s = document.createElement("span");
    s.className = "sparkle";
    s.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    s.style.left = (rect.left + rect.width/2 + (Math.random()*120 - 60)) + "px";
    s.style.top = (rect.top + window.scrollY + (Math.random()*20 - 10)) + "px";
    document.body.appendChild(s);
    setTimeout(() => s.remove(), 1300);
  }
}

magicBtn.addEventListener("click", () => {
  if (magicBtn.classList.contains("shaking")) return;
  magicBtn.classList.add("shaking");
  slotOverlay.classList.remove("hidden");
  spawnSparkles();

  setTimeout(() => {
    magicBtn.classList.remove("shaking");
    slotOverlay.classList.add("hidden");

    if (selectedIngredients.size === 0){
      renderSignatureRecipes();
    } else {
      currentTab = "minimalist";
      renderFilteredRecipes();
      if (filteredRecipes.filter(r => r.style === "minimalist").length === 0 &&
          filteredRecipes.filter(r => r.style === "premium").length > 0){
        currentTab = "premium";
        updateTabUI();
        renderRecipesForTab();
      }
    }
    document.getElementById("recipeSectionTitle").scrollIntoView({ behavior: "smooth", block: "start" });
  }, 1400);
});

/* ===================== 彈窗（Modal）控制 ===================== */
function openRecipeModal(recipeId) {
  const recipe = recipes.find(r => r.id === recipeId);
  if (!recipe) return;

  // 填入彈窗標題與時間
  document.getElementById('modal-title').textContent = recipe.name;
  document.getElementById('modal-time').textContent = '⏱ ' + recipe.time;

  // 填入食材標籤
  document.getElementById('modal-ingredients').innerHTML = recipe.ingredients
    .map(ing => `<span class="inline-block bg-indigo-50 text-indigo-600 font-bold text-xs px-3 py-1 rounded-full border border-indigo-200">${ing}</span>`)
    .join('');

  // 填入步驟
  if (recipe.instructions && recipe.instructions.length > 0) {
    document.getElementById('modal-steps').innerHTML = recipe.instructions.map((step, index) => `
      <li class="flex items-start gap-3">
        <span class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-extrabold text-white" style="background:var(--magic-purple);">${index + 1}</span>
        <p class="text-sm text-gray-600 leading-relaxed pt-0.5">${step}</p>
      </li>
    `).join('');
  } else {
    document.getElementById('modal-steps').innerHTML = `
      <li class="text-sm text-gray-500 italic">詳細步驟即將加入，敬請期待！</li>
    `;
  }

  // 顯示彈窗
  const modal = document.getElementById('recipe-modal');
  modal.classList.remove('hidden');
  // 防止背景捲動
  document.body.style.overflow = 'hidden';
}

function closeRecipeModal() {
  document.getElementById('recipe-modal').classList.add('hidden');
  document.body.style.overflow = '';
}

/* ===================== 初始化 ===================== */
renderIngredientGroups();
renderSignatureRecipes();
</script>
<!-- ===================== 彈窗 Modal ===================== -->
<div id="recipe-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background: rgba(30,27,58,0.55); backdrop-filter: blur(4px);">
  <!-- 點擊背景關閉 -->
  <div class="absolute inset-0" onclick="closeRecipeModal()"></div>

  <!-- 彈窗本體 -->
  <div class="relative bg-white rounded-3xl shadow-2xl w-full max-w-lg max-h-[85vh] overflow-y-auto flex flex-col" style="animation: rise .3s ease forwards;">

    <!-- 彈窗頂部紫色 Banner -->
    <div class="rounded-t-3xl px-6 pt-6 pb-5 text-white flex-shrink-0" style="background: linear-gradient(120deg, var(--magic-purple-dark), var(--magic-purple) 60%, #8385f5);">
      <div class="flex justify-between items-start gap-3">
        <div>
          <p class="text-xs font-bold opacity-75 mb-1">🪄 魔法步驟解鎖！</p>
          <h2 id="modal-title" class="font-display font-extrabold text-xl sm:text-2xl leading-snug"></h2>
          <p id="modal-time" class="text-sm mt-1 opacity-80 font-semibold"></p>
        </div>
        <button onclick="closeRecipeModal()" class="flex-shrink-0 w-8 h-8 rounded-full bg-white bg-opacity-20 hover:bg-opacity-40 transition flex items-center justify-center text-white font-bold text-lg leading-none">✕</button>
      </div>
    </div>

    <!-- 彈窗內容 -->
    <div class="px-6 py-5 space-y-5">

      <!-- 所需食材 -->
      <div>
        <h3 class="font-display font-bold text-sm mb-2" style="color:var(--magic-purple-dark);">🧺 所需食材</h3>
        <div id="modal-ingredients" class="flex flex-wrap gap-2"></div>
      </div>

      <!-- 分隔線 -->
      <hr class="border-gray-100" />

      <!-- 詳細步驟 -->
      <div>
        <h3 class="font-display font-bold text-sm mb-3" style="color:var(--magic-purple-dark);">📋 詳細步驟</h3>
        <ul id="modal-steps" class="space-y-4"></ul>
      </div>

    </div>

    <!-- 底部按鈕 -->
    <div class="px-6 pb-6 flex-shrink-0">
      <button onclick="closeRecipeModal()" class="w-full py-3 rounded-2xl font-display font-bold text-white text-base transition" style="background: linear-gradient(135deg, var(--magic-purple), #8385f5);">
        收起魔法 🪄
      </button>
    </div>
  </div>
</div>


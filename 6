  }
  body{
    font-family:'Noto Sans TC','Baloo 2',sans-serif;
    background-color: var(--bg-cream);
    background-image:
      radial-gradient(circle at 10% 10%, rgba(99,102,241,0.10), transparent 35%),
      radial-gradient(circle at 90% 20%, rgba(245,158,11,0.12), transparent 35%),
      radial-gradient(circle at 50% 90%, rgba(99,102,241,0.08), transparent 40%);
    color: var(--ink);
  }
  .font-display{ font-family:'Baloo 2', sans-serif; }

  .ingredient-card{
    transition: transform .15s ease, box-shadow .15s ease, background-color .15s ease;
    box-shadow: 0 2px 0 rgba(30,27,58,0.08);
  }
  .ingredient-card:hover{ transform: translateY(-2px); }
  input[type=checkbox]:checked + .ingredient-card{
    background: linear-gradient(135deg, var(--magic-purple), #8385f5);
    color: white;
    transform: translateY(-3px) rotate(-1deg);
    box-shadow: 0 6px 14px rgba(99,102,241,0.35);
  }
  input[type=checkbox]:checked + .ingredient-card .ing-emoji{
    transform: scale(1.15) rotate(8deg);
  }
  .ing-emoji{ transition: transform .15s ease; }

  .magic-btn{
    background: linear-gradient(135deg, var(--magic-purple) 0%, #8385f5 50%, var(--food-yellow) 100%);
    box-shadow: 0 8px 0 var(--magic-purple-dark), 0 12px 20px rgba(99,102,241,0.4);
    transition: transform .08s ease, box-shadow .08s ease;
  }
  .magic-btn:active{
    transform: translateY(6px);
    box-shadow: 0 2px 0 var(--magic-purple-dark), 0 4px 10px rgba(99,102,241,0.4);
  }
  .magic-btn.shaking{
    animation: shake .5s infinite;
  }
  @keyframes shake{
    0%,100%{ transform: rotate(0deg) translateX(0); }
    20%{ transform: rotate(-3deg) translateX(-3px); }
    40%{ transform: rotate(3deg) translateX(3px); }
    60%{ transform: rotate(-2deg) translateX(-2px); }
    80%{ transform: rotate(2deg) translateX(2px); }
  }

  .slot-reel{
    height: 3.2rem;
    overflow:hidden;
    position:relative;
  }
  .slot-reel-inner{
    animation: spin-reel .12s linear infinite;
  }
  @keyframes spin-reel{
    0%{ transform: translateY(0); }
    100%{ transform: translateY(-3.2rem); }
  }

  .recipe-card{
    transition: transform .2s ease, box-shadow .2s ease;
    opacity:0; transform: translateY(14px) scale(.97);
    animation: rise .45s ease forwards;
  }
  .recipe-card:hover{ transform: translateY(-4px); box-shadow: 0 14px 24px rgba(30,27,58,0.12); }
  @keyframes rise{
    to{ opacity:1; transform: translateY(0) scale(1); }
  }

  .tab-btn{ transition: all .2s ease; }
  .tab-btn.active-minimalist{
    background: var(--ink); color:#fff;
  }
  .tab-btn.active-premium{
    background: linear-gradient(135deg, var(--food-yellow), #fbbf24); color:#3b2a06;
  }

  .sparkle{ position:absolute; pointer-events:none; font-size:1.4rem; animation: float-up 1.2s ease-out forwards; }
  @keyframes float-up{
    0%{ opacity:1; transform: translateY(0) scale(0.6); }
    100%{ opacity:0; transform: translateY(-60px) scale(1.3) rotate(25deg); }

  ::-webkit-scrollbar-thumb{ background: var(--magic-purple); border-radius:4px; }

  .wobble-hover:hover{ animation: wobble 0.5s ease; }
  @keyframes wobble{
    0%,100%{ transform: rotate(0); }
    25%{ transform: rotate(-4deg); }
